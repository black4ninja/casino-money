# Frontend
VITE_PORT=8484

# Backend
PARSE_SERVER_PORT=1448
PARSE_SERVER_URL=http://localhost:1448/parse

# MongoDB Atlas
MONGODB_URI=mongodb://<user>:<password>@<host>/<db>?<options>

# Parse Keys (generar con: npx parse-server --help | npx generate-random-string)
PARSE_APP_ID=replace-with-app-id
PARSE_MASTER_KEY=replace-with-master-key
PARSE_CLIENT_KEY=replace-with-client-key

# Frontend Parse keys (VITE_ prefix exposes to browser)
VITE_PARSE_APP_ID=replace-with-app-id
VITE_PARSE_CLIENT_KEY=replace-with-client-key
VITE_PARSE_SERVER_URL=http://localhost:1448/parse

# App
APP_NAME=CasinoGame

# Auth (JWT) — generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-random-96-hex-chars
JWT_REFRESH_SECRET=replace-with-different-random-96-hex-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
